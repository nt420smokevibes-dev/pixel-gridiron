            border:2px solid #fff; 
            font-size:12px; 
            display:flex; 
            align-items:center; 
            justify-content:center; 
            font-weight:bold; 
            touch-action:none;
        }
        
        .actionBtn:active { 
            transform:scale(0.85); 
            opacity:0.8;
        }
        
        .btn-y { top:5px; left:35px; background:#9932CC; color:#fff; }
        .btn-x { top:30px; left:5px; background:#FFD700; color:#000; }
        .btn-b { top:30px; left:65px; background:#32CD32; color:#fff; }
        .btn-a { top:55px; left:35px; background:#1E90FF; color:#fff; }
    </style>
</head>
<body>
    <canvas id="gameCanvasEl"></canvas>
    <canvas id="vramCanvas" width="128" height="120"></canvas>
    
    <div id="gameUI">
        <div id="scoreEl">HOME 0 - 0 AWAY</div>
        <div id="downEl">1st & 10</div>
        <div id="timeEl">Q1 2:00</div>
    </div>

    <div id="gameMenu" class="modal active">
        <h1 class="title">BLIDZ</h1>
        <p style="color:#888; font-size:9px; margin-bottom:10px;">ARCADE FOOTBALL • WASM</p>
        <button id="startBtn" class="menuBtn quick-game">START GAME</button>
        <p style="font-size:8px; margin-top:10px; color:#666;">Joystick = Move<br>A = Action • B = Sprint</p>
    </div>

    <div id="playSelect" class="modal">
        <h2 style="margin:0 0 12px; font-size:18px;">SELECT PLAY</h2>
        <button id="runBtn" class="playBtn run-play">RUN PLAY</button>
        <button id="passBtn" class="playBtn pass-play">PASS PLAY</button>
    </div>

    <div id="controls">
        <div id="joystick"><div id="joystickKnob"></div></div>
        <div id="buttonCluster">
            <button id="btnY" class="actionBtn btn-y">Y</button>
            <button id="btnX" class="actionBtn btn-x">X</button>
            <button id="btnB" class="actionBtn btn-b">B</button>
            <button id="btnA" class="actionBtn btn-a">A</button>
        </div>
    </div>

    <script type="module">
        import * as THREE from "https://esm.sh/three@0.177.0";
        
        // Prevent default touch behaviors
        document.addEventListener('touchmove', (e) => e.preventDefault(), {passive: false});
        
        // ====================== WASM GLYPH CORE ======================
        const WASM = {
            lut: {
                n: new Uint8Array(256), u: new Uint8Array(256), b: new Uint8Array(256),
                d: new Uint8Array(256), q: new Uint8Array(256), p: new Uint8Array(256)
            },
            vram: new Uint8Array(960),
            
            init() {
                for (let i = 0; i < 256; i++) {
                    this.lut.n[i] = i;
                    this.lut.u[i] = (~i) & 0xFF;
                    this.lut.b[i] = ((i & 0xF0) >> 4) | ((i & 0x0F) << 4);
                    this.lut.d[i] = i ^ 0xAA;
                    this.lut.q[i] = i & 0x03;
                    this.lut.p[i] = ((i & 0xAA) >> 1) | ((i & 0x55) << 1);
                }
                console.log('✓ WASM init (3000:1 compression)');
            },
            
            exec(glyph, val) {
                if (glyph.length === 1) return this.lut[glyph] ? this.lut[glyph][val] : val;
                let r = val, i = 0;
                while (i < glyph.length) {
                    const c = glyph[i];
                    if (i + 1 < glyph.length) {
                        const nx = glyph[i + 1];
                        if (nx === 'x') {
                            const l = this.lut[c][r];
                            i += 2;
                            r = l ^ this.lut[glyph[i]][r];
                            i++;
                            continue;
                        } else if (nx === 'o') {
                            const l = this.lut[c][r];
                            i += 2;
                            r = l | this.lut[glyph[i]][r];
                            i++;
                            continue;
                        }
                    }
                    r = this.lut[c] ? this.lut[c][r] : r;
                    i++;
                }
                return r;
            }
        };
        
        WASM.init();
        
        // ====================== VRAM RENDERER ======================
        const vramCv = document.getElementById('vramCanvas');
        const vramCtx = vramCv.getContext('2d');
        const palette = (() => {
            const p = Array(256).fill('#000');
            p[0]='#000'; p[1]='#2a2'; p[2]='#fff'; p[3]='#fd0'; 
            p[4]='#f22'; p[5]='#22f'; p[6]='#850';
            return p;
        })();
        
        function renderVRAM() {
            for (let y = 0; y < 30; y++) {
                for (let x = 0; x < 32; x++) {
                    vramCtx.fillStyle = palette[WASM.vram[y * 32 + x]];
                    vramCtx.fillRect(x * 4, y * 4, 4, 4);
                }
            }
        }
        
        function drawField() {
            WASM.vram.fill(1);
            for (let i = 0; i < 11; i++) {
                const y = Math.floor(2 + i * 2.5);
                for (let x = 0; x < 32; x++) WASM.vram[y * 32 + x] = 2;
            }
            for (let x = 0; x < 32; x++) WASM.vram[15 * 32 + x] = 3;
            for (let x = 0; x < 32; x++) {
                WASM.vram[0 * 32 + x] = 4; WASM.vram[1 * 32 + x] = 4;
                WASM.vram[28 * 32 + x] = 5; WASM.vram[29 * 32 + x] = 5;
            }
        }
        
        drawField();
        
        // ====================== TOUCH CONTROLS ======================
        const joy = {x:0, y:0};
        const btns = {A:false, B:false, X:false, Y:false};
        
        const joyEl = document.getElementById('joystick');
        const knob = document.getElementById('joystickKnob');
        
        let joyTouchId = null;
        
        joyEl.addEventListener('touchstart', (e) => {
            if (joyTouchId === null) {
                joyTouchId = e.changedTouches[0].identifier;
                handleJoyMove(e.changedTouches[0]);
            }
            e.preventDefault();
        }, {passive: false});
        
        joyEl.addEventListener('touchmove', (e) => {
            for (let touch of e.changedTouches) {
                if (touch.identifier === joyTouchId) {
                    handleJoyMove(touch);
                    break;
                }
            }
            e.preventDefault();
        }, {passive: false});
        
        joyEl.addEventListener('touchend', (e) => {
            for (let touch of e.changedTouches) {
                if (touch.identifier === joyTouchId) {
                    joyTouchId = null;
                    joy.x = 0; 
                    joy.y = 0;
                    knob.style.left = '27px';
                    knob.style.top = '27px';
                    break;
                }
            }
            e.preventDefault();
        }, {passive: false});
        
        function handleJoyMove(touch) {
            const rect = joyEl.getBoundingClientRect();
            const centerX = rect.left + rect.width / 2;
            const centerY = rect.top + rect.height / 2;
            const dx = touch.clientX - centerX;
            const dy = touch.clientY - centerY;
            const maxDist = 27;
            
            joy.x = Math.max(-1, Math.min(1, dx / maxDist));
            joy.y = Math.max(-1, Math.min(1, dy / maxDist));
            
            knob.style.left = (27 + joy.x * maxDist) + 'px';
            knob.style.top = (27 + joy.y * maxDist) + 'px';
        }
        
        // Button touches
        ['A','B','X','Y'].forEach(btn => {
            const el = document.getElementById('btn' + btn);
            
            el.addEventListener('touchstart', (e) => {
                btns[btn] = true;
                e.preventDefault();
            }, {passive: false});
            
            el.addEventListener('touchend', (e) => {
                btns[btn] = false;
                e.preventDefault();
            }, {passive: false});
        });
        
        // ====================== THREE.JS GAME ======================
        const scene = new THREE.Scene();
        scene.fog = new THREE.Fog(0x006600, 20, 80);
        
        const camera = new THREE.PerspectiveCamera(
            75, 
            window.innerWidth / (window.innerHeight - 100), 
            0.1, 
            1000
        );
        camera.position.set(0, 3, 10);
        
        const canvas = document.getElementById('gameCanvasEl');
        const renderer = new THREE.WebGLRenderer({canvas, antialias: false});
        renderer.setSize(window.innerWidth, window.innerHeight - 100);
        renderer.shadowMap.enabled = true;
        
        const ambientLight = new THREE.AmbientLight(0xffffff, 0.6);
        scene.add(ambientLight);
        
        const sunLight = new THREE.DirectionalLight(0xffffee, 0.8);
        sunLight.position.set(20, 40, 15);
        sunLight.castShadow = true;
        scene.add(sunLight);
        
        // Field
        const fieldGeo = new THREE.PlaneGeometry(53, 120);
        const fieldMat = new THREE.MeshStandardMaterial({color: 0x228B22});
        const field = new THREE.Mesh(fieldGeo, fieldMat);
        field.rotation.x = -Math.PI / 2;
        field.receiveShadow = true;
        scene.add(field);
        
        // Yard lines
        const lineMat = new THREE.LineBasicMaterial({color: 0xffffff});
        for (let z = -50; z <= 50; z += 10) {
            const pts = [
                new THREE.Vector3(-26, 0.01, z), 
                new THREE.Vector3(26, 0.01, z)
            ];
            const geo = new THREE.BufferGeometry().setFromPoints(pts);
            scene.add(new THREE.Line(geo, lineMat));
        }
        
        // Player
        const playerGeo = new THREE.CapsuleGeometry(0.4, 1.2, 4, 8);
        const redMat = new THREE.MeshStandardMaterial({color: 0xff4444});
        const player = new THREE.Mesh(playerGeo, redMat);
        player.position.set(0, 0.8, 0);
        player.castShadow = true;
        scene.add(player);
        
        // Ball
        const ballGeo = new THREE.SphereGeometry(0.3, 6, 4);
        ballGeo.scale(1, 0.6, 1.4);
        const ballMat = new THREE.MeshStandardMaterial({color: 0x8B4513});
        const ball = new THREE.Mesh(ballGeo, ballMat);
        ball.position.set(0, 0.5, 0);
        ball.castShadow = true;
        scene.add(ball);
        
        // Game state
        let gameState = 'menu';
        let quarter = 1, timeLeft = 120, down = 1, yardsToGo = 10;
        let homeScore = 0, awayScore = 0;
        
        // UI handlers
        document.getElementById('startBtn').addEventListener('click', () => {
            document.getElementById('gameMenu').classList.remove('active');
            document.getElementById('playSelect').classList.add('active');
        });
        
        document.getElementById('runBtn').addEventListener('click', () => {
            document.getElementById('playSelect').classList.remove('active');
            gameState = 'playing';
        });
        
        document.getElementById('passBtn').addEventListener('click', () => {
            document.getElementById('playSelect').classList.remove('active');
            gameState = 'playing';
        });
        
        // Game loop
        let lastTime = Date.now();
        
        function animate() {
            requestAnimationFrame(animate);
            
            if (gameState === 'playing') {
                // Move player
                const speed = btns.B ? 0.15 : 0.08;
                player.position.x += joy.x * speed;
                player.position.z -= joy.y * speed;
                
                // Bounds
                player.position.x = Math.max(-26, Math.min(26, player.position.x));
                player.position.z = Math.max(-55, Math.min(55, player.position.z));
                
                // Ball follows
                ball.position.x = player.position.x;
                ball.position.z = player.position.z;
                
                // Camera follow
                camera.position.x = player.position.x;
                camera.position.z = player.position.z + 10;
                camera.lookAt(player.position);
                
                // Clock
                const now = Date.now();
                if (now - lastTime >= 1000) {
                    timeLeft--;
                    lastTime = now;
                    if (timeLeft <= 0) {
                        quarter++;
                        timeLeft = 120;
                        if (quarter > 4) gameState = 'gameover';
                    }
                }
                
                // HUD
                const m = Math.floor(timeLeft / 60);
                const s = timeLeft % 60;
                document.getElementById('scoreEl').textContent = 
                    `HOME ${homeScore} - ${awayScore} AWAY`;
                document.getElementById('downEl').textContent = 
                    `${down}${['st','nd','rd','th'][down-1] || 'th'} & ${yardsToGo}`;
                document.getElementById('timeEl').textContent = 
                    `Q${quarter} ${m}:${s.toString().padStart(2,'0')}`;
                
                // VRAM minimap
                const px = Math.floor(((player.position.x + 26) / 52) * 31);
                const pz = Math.floor(((player.position.z + 60) / 120) * 29);
                drawField();
                if (px >= 0 && px < 32 && pz >= 0 && pz < 30) {
                    WASM.vram[pz * 32 + px] = 4;
                }
            }
            
            renderVRAM();
            renderer.render(scene, camera);
        }
        
        animate();
        
        // Handle resize
        window.addEventListener('resize', () => {
            camera.aspect = window.innerWidth / (window.innerHeight - 100);
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight - 100);
        });
        
        console.log('✓ BLIDZ loaded! Touch controls ready.');
        console.log('✓ WASM: qxp, pob, db, bd glyphs active');
    </script>
</body>
</html>

