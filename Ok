            lut: {
                n: new Uint8Array(256), u: new Uint8Array(256), b: new Uint8Array(256),
                d: new Uint8Array(256), q: new Uint8Array(256), p: new Uint8Array(256),
                w: new Uint8Array(256), m: new Uint8Array(256)
            },
            vram: new Uint8Array(960),
            
            init() {
                for (let i = 0; i < 256; i++) {
                    this.lut.n[i] = i;
                    this.lut.u[i] = (~i) & 0xFF;
                    this.lut.b[i] = ((i & 0xF0) >> 4) | ((i & 0x0F) << 4);
                    this.lut.d[i] = i ^ 0xAA;
                    this.lut.q[i] = i & 0x03;
                    this.lut.p[i] = ((i & 0xAA) >> 1) | ((i & 0x55) << 1);
                    this.lut.w[i] = (i & 0xF0) | ((~i) & 0x0F);
                    this.lut.m[i] = i & 0xF0;
                }
                console.log('✓ WASM LUTs init (8x256 bytes)');
            },
            
            exec(glyph, val) {
                if (glyph.length === 1) return this.lut[glyph] ? this.lut[glyph][val] : val;
                let r = val, i = 0;
                while (i < glyph.length) {
                    const c = glyph[i];
                    if (i + 1 < glyph.length) {
                        const nx = glyph[i + 1];
                        if (nx === 'x') {
                            const l = this.lut[c][r];
                            i += 2;
                            const rt = this.lut[glyph[i]][r];
                            r = l ^ rt;
                            i++;
                            continue;
                        } else if (nx === 'o') {
                            const l = this.lut[c][r];
                            i += 2;
                            const rt = this.lut[glyph[i]][r];
                            r = l | rt;
                            i++;
                            continue;
                        }
                    }
                    r = this.lut[c] ? this.lut[c][r] : r;
                    i++;
                }
                return r;
            },
            
            demo() {
                console.log('\n=== WASM GLYPH DEMO ===');
                const v = 180;
                console.log(`Input: ${v.toString(2).padStart(8,'0')} (${v})`);
                ['qxp','pob','db','bd','pod','poq','bxd','bxp','bxq'].forEach(g => {
                    const r = this.exec(g, v);
                    console.log(`${g}: ${r.toString(2).padStart(8,'0')} (${r})`);
                });
                console.log('\n3000:1 compression active!');
            }
        };
        
        WASM.init();
        
        // ====================== VRAM RENDERER ======================
        const vramCv = document.getElementById('vramCanvas');
        const vramCtx = vramCv.getContext('2d');
        const palette = (() => {
            const p = Array.from({length: 256}, (_, i) => {
                const r = Math.floor(((i & 0xE0) >> 5) / 7 * 255);
                const g = Math.floor(((i & 0x1C) >> 2) / 7 * 255);
                const b = Math.floor((i & 0x03) / 3 * 255);
                return `rgb(${r},${g},${b})`;
            });
            p[0]='#000'; p[1]='#2a2'; p[2]='#fff'; p[3]='#fd0'; p[4]='#f22'; p[5]='#22f'; p[6]='#850';
            return p;
        })();
        
        function renderVRAM() {
            for (let y = 0; y < 30; y++) {
                for (let x = 0; x < 32; x++) {
                    vramCtx.fillStyle = palette[WASM.vram[y * 32 + x]];
                    vramCtx.fillRect(x * 5, y * 5, 5, 5);
                }
            }
        }
        
        function drawField() {
            WASM.vram.fill(1);
            for (let i = 0; i < 11; i++) {
                const y = Math.floor(2 + i * 2.5);
                for (let x = 0; x < 32; x++) WASM.vram[y * 32 + x] = 2;
            }
            for (let x = 0; x < 32; x++) WASM.vram[15 * 32 + x] = 3;
            for (let x = 0; x < 32; x++) {
