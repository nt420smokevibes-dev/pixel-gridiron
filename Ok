            }
            for (let x = 0; x < 32; x++) WASM.vram[15 * 32 + x] = 3;
            for (let x = 0; x < 32; x++) {
                WASM.vram[0 * 32 + x] = 4; WASM.vram[1 * 32 + x] = 4;
