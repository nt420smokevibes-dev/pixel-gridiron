<html>
<head>
    <meta charset="UTF-8">
    <title>BLIDZ WASM Test</title>
    <style>
        body { margin: 0; background: #000; color: #0f0; font-family: monospace; padding: 20px; }
        canvas { border: 2px solid #0f0; display: block; margin: 20px auto; }
        button { background: #0f0; color: #000; padding: 10px 20px; margin: 5px; border: none; font-weight: bold; cursor: pointer; }
        #log { background: #111; border: 1px solid #0f0; padding: 15px; margin: 20px auto; max-width: 800px; white-space: pre; font-size: 12px; max-height: 400px; overflow-y: auto; }
    </style>
</head>
<body>
    <h1 style="text-align: center;">⚡ WASM GLYPH SYSTEM ⚡</h1>
    <canvas id="c" width="640" height="600"></canvas>
    <div style="text-align: center;">
        <button onclick="test1()">Basic Ops</button>
        <button onclick="test2()">Composite</button>
        <button onclick="test3()">Symmetry</button>
        <button onclick="test4()">Field</button>
        <button onclick="bench()">Benchmark</button>
    </div>
    <div id="log">Ready...</div>

    <script>
        // WASM Core
        const W = {
            lut: { n: new Uint8Array(256), u: new Uint8Array(256), b: new Uint8Array(256), 
                   d: new Uint8Array(256), q: new Uint8Array(256), p: new Uint8Array(256) },
            vram: new Uint8Array(960),
            
            init() {
                for (let i = 0; i < 256; i++) {
                    this.lut.n[i] = i;
                    this.lut.u[i] = (~i) & 0xFF;
                    this.lut.b[i] = ((i & 0xF0) >> 4) | ((i & 0x0F) << 4);
                    this.lut.d[i] = i ^ 0xAA;
                    this.lut.q[i] = i & 0x03;
                    this.lut.p[i] = ((i & 0xAA) >> 1) | ((i & 0x55) << 1);
                }
            },
            
            exec(g, v) {
                if (g.length === 1) return this.lut[g] ? this.lut[g][v] : v;
                let r = v, i = 0;
                while (i < g.length) {
                    const c = g[i];
                    if (i + 1 < g.length && g[i + 1] === 'x') {
                        const l = this.lut[c][r];
                        i += 2;
                        const rt = this.lut[g[i]][r];
                        r = l ^ rt;
                        i++;
                    } else if (i + 1 < g.length && g[i + 1] === 'o') {
                        const l = this.lut[c][r];
                        i += 2;
                        const rt = this.lut[g[i]][r];
                        r = l | rt;
                        i++;
                    } else {
                        r = this.lut[c] ? this.lut[c][r] : r;
                        i++;
                    }
                }
                return r;
            }
        };
        
        W.init();
        
        // Renderer
        const cv = document.getElementById('c');
        const ctx = cv.getContext('2d');
        const pal = Array.from({length: 256}, (_, i) => {
            const r = Math.floor(((i & 0xE0) >> 5) / 7 * 255);
            const g = Math.floor(((i & 0x1C) >> 2) / 7 * 255);
            const b = Math.floor((i & 0x03) / 3 * 255);
            return `rgb(${r},${g},${b})`;
        });
        pal[0]='#000'; pal[1]='#2a2'; pal[2]='#fff'; pal[3]='#fd0'; pal[4]='#f22'; pal[5]='#22f';
        
        function draw() {
            for (let y = 0; y < 30; y++) {
                for (let x = 0; x < 32; x++) {
                    ctx.fillStyle = pal[W.vram[y * 32 + x]];
                    ctx.fillRect(x * 20, y * 20, 20, 20);
                }
            }
        }
        
        function log(m) {
            document.getElementById('log').textContent += m + '\n';
        }
        
        // Tests
        function test1() {
            log('\n=== BASIC OPS ===');
            const v = 0b10101010;
            log(`Input: ${v.toString(2)} (${v})`);
            ['n','u','b','d','q','p'].forEach(g => {
                log(`${g}: ${W.exec(g,v).toString(2).padStart(8,'0')}`);
            });
        }
        
        function test2() {
            log('\n=== COMPOSITE OPS ===');
            const v = 180;
            log(`Input: ${v}`);
            ['qxp','pob','db','bd','pod','poq','bxd','bxp','bxq'].forEach(g => {
                log(`${g}: ${W.exec(g,v).toString(2).padStart(8,'0')} (${W.exec(g,v)})`);
            });
        }
        
        function test3() {
            log('\n=== SYMMETRY ===');
            const w=16, h=15;
            for (let y=0; y<h; y++) {
                for (let x=0; x<w; x++) {
                    const v = ((x+y)%2)*255;
                    W.vram[y*32+x] = v;
                    W.vram[y*32+(31-x)] = W.lut.b[v];
                    W.vram[(29-y)*32+x] = W.lut.u[v];
                    W.vram[(29-y)*32+(31-x)] = W.lut.u[W.lut.b[v]];
                }
            }
            log('✓ Quadrant expanded to 4!');
            draw();
        }
        
        function test4() {
            log('\n=== FIELD ===');
            W.vram.fill(1);
            for (let i=0; i<11; i++) {
                const y = Math.floor(2 + i*2.5);
                for (let x=0; x<32; x++) W.vram[y*32+x]=2;
            }
            for (let x=0; x<32; x++) W.vram[15*32+x]=3;
            for (let x=0; x<32; x++) {
                W.vram[0*32+x]=4; W.vram[1*32+x]=4;
                W.vram[28*32+x]=5; W.vram[29*32+x]=5;
            }
            log('✓ Field drawn (960 bytes)');
            draw();
        }
        
        function bench() {
            log('\n=== BENCHMARK ===');
            const n = 100000;
            const t0 = performance.now();
            for (let i=0; i<n; i++) {
                W.exec('qxp', i&0xFF);
                W.exec('pob', i&0xFF);
                W.exec('db', i&0xFF);
            }
            const t1 = performance.now();
            const ms = t1-t0;
            log(`${n} glyphs in ${ms.toFixed(2)}ms`);
            log(`${((n*3/ms)*1000).toFixed(0)} ops/sec`);
        }
        
        log('✓ WASM initialized\n✓ 960-byte VRAM\n✓ Click buttons!');
        test4();
    </script>
</body>
