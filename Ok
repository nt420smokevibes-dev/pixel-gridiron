        document.addEventListener('keydown', (e) => {
            if (e.key === 'w' || e.key === 'W') WASM.demo();
            if (e.key === 'ArrowUp') joy.y = -1;
            if (e.key === 'ArrowDown') joy.y = 1;
            if (e.key === 'ArrowLeft') joy.x = -1;
            if (e.key === 'ArrowRight') joy.x = 1;
            if (e.key === ' ' || e.key === 'z') btns.A = true;
            if (e.key === 'x') btns.B = true;
        });
        
        document.addEventListener('keyup', (e) => {
            if (e.key.startsWith('Arrow')) { joy.x = 0; joy.y = 0; }
            if (e.key === ' ' || e.key === 'z') btns.A = false;
            if (e.key === 'x') btns.B = false;
        });
        
        // ====================== THREE.JS GAME ======================
        const scene = new THREE.Scene();
        scene.fog = new THREE.Fog(0x006600, 20, 80);
        
        const camera = new THREE.PerspectiveCamera(75, window.innerWidth/(window.innerHeight-110), 0.1, 1000);
        camera.position.set(0, 3, 10);
        
        const renderer = new THREE.WebGLRenderer({canvas: document.getElementById('gameCanvasEl'), antialias: false});
        renderer.setSize(window.innerWidth, window.innerHeight - 110);
        renderer.shadowMap.enabled = true;
        
        const ambientLight = new THREE.AmbientLight(0xffffff, 0.6);
        scene.add(ambientLight);
        
        const sunLight = new THREE.DirectionalLight(0xffffee, 0.8);
        sunLight.position.set(20, 40, 15);
        sunLight.castShadow = true;
        scene.add(sunLight);
        
        // Field
        const fieldGeo = new THREE.PlaneGeometry(53, 120);
        const fieldMat = new THREE.MeshStandardMaterial({color: 0x228B22});
        const field = new THREE.Mesh(fieldGeo, fieldMat);
        field.rotation.x = -Math.PI/2;
        field.receiveShadow = true;
        scene.add(field);
        
        // Yard lines
        const lineMat = new THREE.LineBasicMaterial({color: 0xffffff});
        for (let z = -50; z <= 50; z += 10) {
            const pts = [new THREE.Vector3(-26, 0.01, z), new THREE.Vector3(26, 0.01, z)];
            const geo = new THREE.BufferGeometry().setFromPoints(pts);
            scene.add(new THREE.Line(geo, lineMat));
        }
        
        // Players
        const playerGeo = new THREE.CapsuleGeometry(0.4, 1.2, 4, 8);
        const redMat = new THREE.MeshStandardMaterial({color: 0xff4444});
        const player = new THREE.Mesh(playerGeo, redMat);
        player.position.set(0, 0.8, 0);
        player.castShadow = true;
        scene.add(player);
        
        // Ball
        const ballGeo = new THREE.SphereGeometry(0.3, 6, 4);
        ballGeo.scale(1, 0.6, 1.4);
        const ballMat = new THREE.MeshStandardMaterial({color: 0x8B4513});
        const ball = new THREE.Mesh(ballGeo, ballMat);
        ball.position.set(0, 0.5, 0);
        ball.castShadow = true;
        scene.add(ball);
        
        // Game state
        let gameState = 'menu';
        let quarter = 1, timeLeft = 120, down = 1, yardsToGo = 10;
        let homeScore = 0, awayScore = 0;
        
        // UI
        document.getElementById('startBtn').addEventListener('click', () => {
            document.getElementById('gameMenu').classList.remove('active');
            document.getElementById('playSelect').classList.add('active');
        });
        
        document.getElementById('runBtn').addEventListener('click', () => {
            document.getElementById('playSelect').classList.remove('active');
            gameState = 'playing';
        });
        
        document.getElementById('passBtn').addEventListener('click', () => {
            document.getElementById('playSelect').classList.remove('active');
            gameState = 'playing';
        });
        
        // Game loop
        let lastTime = Date.now();
        function animate() {
            requestAnimationFrame(animate);
            
            if (gameState === 'playing') {
                // Move player
                const speed = btns.B ? 0.15 : 0.08;
                player.position.x += joy.x * speed;
                player.position.z -= joy.y * speed;
                
                // Bounds
                player.position.x = Math.max(-26, Math.min(26, player.position.x));
                player.position.z = Math.max(-55, Math.min(55, player.position.z));
                
                // Ball follows
                ball.position.x = player.position.x;
                ball.position.z = player.position.z;
                
                // Camera follow
                camera.position.x = player.position.x;
                camera.position.z = player.position.z + 10;
                camera.lookAt(player.position);
                
                // Clock
                const now = Date.now();
                if (now - lastTime >= 1000) {
                    timeLeft--;
                    lastTime = now;
                    if (timeLeft <= 0) {
                        quarter++;
                        timeLeft = 120;
                        if (quarter > 4) gameState = 'gameover';
                    }
                }
                
                // HUD
                const m = Math.floor(timeLeft / 60);
                const s = timeLeft % 60;
                document.getElementById('scoreEl').textContent = `HOME ${homeScore} - ${awayScore} AWAY`;
                document.getElementById('downEl').textContent = `${down}${['st','nd','rd','th'][down-1] || 'th'} & ${yardsToGo}`;
                document.getElementById('timeEl').textContent = `Q${quarter} ${m}:${s.toString().padStart(2,'0')}`;
                
                // Update VRAM minimap
                const px = Math.floor(((player.position.x + 26) / 52) * 31);
                const pz = Math.floor(((player.position.z + 60) / 120) * 29);
                drawField();
                if (px >= 0 && px < 32 && pz >= 0 && pz < 30) {
                    WASM.vram[pz * 32 + px] = 4;
                }
            }
            
            renderVRAM();
            renderer.render(scene, camera);
        }
        
        animate();
        console.log('✓ BLIDZ loaded! Press W for WASM demo');
    </script>
