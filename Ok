            const dy = t.clientY - rect.top - 55;
            const max = 35;
            joy.x = Math.max(-1, Math.min(1, dx/max));
            joy.y = Math.max(-1, Math.min(1, dy/max));
            knob.style.left = (34 + joy.x*35) + 'px';
            knob.style.top = (34 + joy.y*35) + 'px';
            e.preventDefault();
        });
        
        document.addEventListener('touchend', () => {
            dragging = false;
            joy.x = 0; joy.y = 0;
            knob.style.left = '34px';
            knob.style.top = '34px';
        });
        
        ['A','B','X','Y'].forEach(b => {
            const el = document.getElementById('btn'+b);
            el.addEventListener('touchstart', () => btns[b] = true);
            el.addEventListener('touchend', () => btns[b] = false);
        });
        
        // Keyboard
        document.addEventListener('keydown', (e) => {
            if (e.key === 'w' || e.key === 'W') WASM.demo();
            if (e.key === 'ArrowUp') joy.y = -1;
            if (e.key === 'ArrowDown') joy.y = 1;
            if (e.key === 'ArrowLeft') joy.x = -1;
            if (e.key === 'ArrowRight') joy.x = 1;
            if (e.key === ' ' || e.key === 'z') btns.A = true;
            if (e.key === 'x') btns.B = true;
        });
        
        document.addEventListener('keyup', (e) => {
            if (e.key.startsWith('Arrow')) { joy.x = 0; joy.y = 0; }
            if (e.key === ' ' || e.key === 'z') btns.A = false;
            if (e.key === 'x') btns.B = false;
        });
        
